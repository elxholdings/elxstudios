# Required for WhatsApp redirect.
# Use international format without + or spaces, e.g. 254712345678
NEXT_PUBLIC_WHATSAPP_NUMBER=254700000000

# Optional but recommended. Creates a simple lead database.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional. Sends every project brief to your inbox.
RESEND_API_KEY=
ELX_ADMIN_EMAIL=you@yourdomain.com
RESEND_FROM_EMAIL=Elx Studio <onboarding@yourdomain.com>
