# Required for WhatsApp redirect.
# Use international format without + or spaces, e.g. 254712345678
NEXT_PUBLIC_WHATSAPP_NUMBER=254700000000

# Required for automatic translation beyond English and Simplified Chinese.
# Enable Cloud Translation API (Basic v2) and restrict the key to that API.
GOOGLE_TRANSLATE_API_KEY=

# Supabase project API settings. The anon key is safe for the browser only
# because all exposed tables are protected by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Never expose this key in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Meta Graph API. App ID is public configuration; every other value is server-only.
META_APP_ID=
META_APP_SECRET=
META_GRAPH_API_VERSION=v25.0
# Base64-encoded 32-byte random value used for AES-256-GCM token encryption.
META_TOKEN_ENCRYPTION_KEY=
# Random server secret entered into the Meta webhook configuration screen.
META_WEBHOOK_VERIFY_TOKEN=
# Development/test credentials from WhatsApp > API Setup in the Meta app.
META_WHATSAPP_ACCESS_TOKEN=
META_WHATSAPP_PHONE_NUMBER_ID=
META_WHATSAPP_BUSINESS_ACCOUNT_ID=

# Optional. Sends every project brief to your inbox.
RESEND_API_KEY=
ELX_ADMIN_EMAIL=you@yourdomain.com
RESEND_FROM_EMAIL=Elx Studio <onboarding@yourdomain.com>
